{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/auth"
          },
          {
            "RequestHeader": "X-Forwarded-Prefix",
            "Set": "/auth"
          }
        ]
      },
      "dish-route": {
        "ClusterId": "dish-cluster",
        "Match": {
          "Path": "/dishes/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/dishes"
          },
          {
            "RequestHeader": "X-Forwarded-Prefix",
            "Set": "/dishes"
          }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/orders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/orders"
          },
          {
            "RequestHeader": "X-Forwarded-Prefix",
            "Set": "/orders"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://authservice:80"
          }
        }
      },
      "dish-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://dishservice:80"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://orderservice:80"
          }
        }
      }
    }
  }
}